<script>
/* ─────────────────────────────────────────────
   CURSOR
───────────────────────────────────────────── */
const cur  = document.getElementById('cur');
const curR = document.getElementById('cur-r');
let mx=0, my=0, rx=0, ry=0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cur.style.left = mx + 'px';
  cur.style.top  = my + 'px';
});
(function loop(){
  rx += (mx - rx) * .1;
  ry += (my - ry) * .1;
  curR.style.left = rx + 'px';
  curR.style.top  = ry + 'px';
  requestAnimationFrame(loop);
})();

/* ─────────────────────────────────────────────
   NAV + SCROLL
───────────────────────────────────────────── */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('sc', window.scrollY > 20);
});
document.getElementById('nav-dl').addEventListener('click', () => {
  document.getElementById('dl').scrollIntoView({ behavior: 'smooth' });
});

/* ─────────────────────────────────────────────
   FADE-UP OBSERVER
───────────────────────────────────────────── */
new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
}, { threshold: .11 }).observe.bind(
  new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
  }, { threshold: .11 })
);

// Simpler approach:
const fuObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
}, { threshold: .11 });
document.querySelectorAll('.fu').forEach(el => fuObs.observe(el));

/* ─────────────────────────────────────────────
   MAGNETIC BUTTONS
───────────────────────────────────────────── */
document.querySelectorAll('.btn-p,.btn-o,.n-cta,.dl-btn,.p-btn').forEach(btn => {
  btn.addEventListener('mousemove', e => {
    const r  = btn.getBoundingClientRect();
    const dx = e.clientX - r.left  - r.width  / 2;
    const dy = e.clientY - r.top   - r.height / 2;
    btn.style.transform = `translate(${dx * .13}px, ${dy * .13}px)`;
  });
  btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
});

/* ═══════════════════════════════════════════════
   HERO — PARTICLE GRAVITY
   Purple + Orange mixed particles orbit cursor.
═══════════════════════════════════════════════ */
(function heroParticles() {
  const cvs = document.getElementById('hero-cvs');
  const c   = cvs.getContext('2d');

  function resize() {
    cvs.width  = cvs.offsetWidth;
    cvs.height = cvs.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const mouse = { x: -1e5, y: -1e5, r: 185 };
  window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
  window.addEventListener('mouseleave', () => { mouse.x = -1e5; mouse.y = -1e5; });

  class Particle {
    constructor() {
      this.reset();
      // scatter on init
      this.x = Math.random() * cvs.width;
      this.y = Math.random() * cvs.height;
    }
    reset() {
      this.hx  = Math.random() * cvs.width;
      this.hy  = Math.random() * cvs.height;
      this.x   = this.hx;
      this.y   = this.hy;
      this.sz  = 1.6 + Math.random() * 1.1;
      this.a   = Math.random() * Math.PI * 2;
      this.or  = 13 + Math.random() * 34;
      const isOrange = Math.random() < .32;
      this.col  = isOrange ? '#F97316' : (Math.random() < .5 ? '#8B5CF6' : '#A78BFA');
      this.glow = isOrange ? '#EA580C' : '#6D28D9';
    }
    update() {
      const dx = mouse.x - this.x;
      const dy = mouse.y - this.y;
      const d  = Math.hypot(dx, dy);
      if (d < mouse.r) {
        this.a += .01 + (45 - this.or) * .0014;
        const tx = mouse.x + Math.cos(this.a) * this.or;
        const ty = mouse.y + Math.sin(this.a) * this.or;
        this.x += (tx - this.x) * .09;
        this.y += (ty - this.y) * .09;
      } else {
        this.x += (this.hx - this.x) * .03;
        this.y += (this.hy - this.y) * .03;
      }
    }
    draw() {
      c.beginPath();
      c.arc(this.x, this.y, this.sz, 0, Math.PI * 2);
      c.shadowBlur  = 8;
      c.shadowColor = this.glow;
      c.fillStyle   = this.col;
      c.fill();
    }
  }

  const pts = [];
  for (let i = 0; i < 210; i++) pts.push(new Particle());

  function frame() {
    c.fillStyle = '#050008';
    c.fillRect(0, 0, cvs.width, cvs.height);

    // Ambient center pulse
    const g = c.createRadialGradient(
      cvs.width / 2, cvs.height / 2, 0,
      cvs.width / 2, cvs.height / 2, cvs.width * .44
    );
    g.addColorStop(0, 'rgba(109,40,217,.075)');
    g.addColorStop(1, 'transparent');
    c.fillStyle = g;
    c.fillRect(0, 0, cvs.width, cvs.height);

    for (const p of pts) { p.update(); p.draw(); }
    requestAnimationFrame(frame);
  }
  frame();
})();

/* ═══════════════════════════════════════════════
   WHAT IS DESERAQ — OSCILLATION PARTICLE
   Chaotic wave collapses into circle on hover.
═══════════════════════════════════════════════ */
(function oscillation() {
  const svg = document.getElementById('osc-svg');
  const ln  = document.getElementById('osc-ln');
  const pt  = document.getElementById('osc-pt');
  if (!svg || !ln || !pt) return;

  const N   = 250;
  const CAP = 62;
  let mX = 9e4, mY = 9e4;
  let captured = false, coherence = 0;
  let spd = .18, pos = 0;

  svg.addEventListener('mousemove', e => {
    const p = svg.createSVGPoint();
    p.x = e.clientX; p.y = e.clientY;
    const t = p.matrixTransform(svg.getScreenCTM().inverse());
    mX = t.x; mY = t.y;
  });
  svg.addEventListener('mouseleave', () => { mX = 9e4; mY = 9e4; });

  function frame(t) {
    coherence += ((captured ? 1 : 0) - coherence) * .06;
    let d = '';

    for (let i = 0; i < N; i++) {
      const u = i / (N - 1);

      const cx = (u - .5) * 700 + 50 * Math.sin(u * 11 + t * .0022);
      const cy = 90 * Math.sin(u * 8 + t * .0015)
               + 60 * Math.cos(u * 13 - t * .0018)
               + 40 * Math.sin(u * 21 + t * .0029);

      const ang = u * Math.PI * 2;
      const r   = 150 + 15 * Math.sin(8 * ang + t * .003) + 8 * Math.cos(5 * ang - t * .002);
      const ex  = r * Math.cos(ang);
      const ey  = r * Math.sin(ang);

      const x = cx * (1 - coherence) + ex * coherence;
      const y = cy * (1 - coherence) + ey * coherence;

      d += i === 0 ? `M ${x} ${y}` : ` L ${x} ${y}`;
    }
    if (coherence > .95) d += ' Z';
    ln.setAttribute('d', d);

    spd += ((captured ? 0 : .18) - spd) * .02;

    const tLen = ln.getTotalLength();
    if (tLen > 0) {
      pos = (pos + spd) % tLen;
      const { x, y } = ln.getPointAtLength(pos);
      pt.setAttribute('cx', x);
      pt.setAttribute('cy', y);
    }
    pt.setAttribute('r', 10 + 3 * Math.sin(t * .01));

    const px = parseFloat(pt.getAttribute('cx') || 0);
    const py = parseFloat(pt.getAttribute('cy') || 0);
    captured = Math.hypot(mX - px, mY - py) < CAP;

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();

/* ═══════════════════════════════════════════════
   HOW TO USE — HEXAGON ROTATING PRISM
   Mouse left/right controls rotation direction.
═══════════════════════════════════════════════ */
(function hexPrism() {
  const cvs = document.getElementById('hex-cvs');
  if (!cvs) return;
  const c = cvs.getContext('2d');

  function resize() {
    const r    = cvs.parentElement.getBoundingClientRect();
    cvs.width  = r.width  || 400;
    cvs.height = r.height || r.width || 400;
  }
  resize();
  new ResizeObserver(resize).observe(cvs.parentElement);
  window.addEventListener('resize', resize);

  // Purple-dominant palette with orange highlights
  const COLS = ['#5B21B6','#7C3AED','#8B5CF6','#A78BFA','#8B5CF6','#8B5CF6','#F97316'];
  let rotDir = 1;
  window.addEventListener('mousemove', e => {
    rotDir = e.clientX > window.innerWidth / 2 ? 1 : -1;
  });

  const RAD = 120, DEPTH = 110, PPE = 11;
  const front = [], back = [], parts = [];

  for (let i = 0; i < 6; i++) {
    const a = (Math.PI * 2 / 6) * i - Math.PI / 6;
    front.push({ x: Math.cos(a) * RAD, y: Math.sin(a) * RAD, z:  DEPTH / 2 });
    back.push({  x: Math.cos(a) * RAD, y: Math.sin(a) * RAD, z: -DEPTH / 2 });
  }

  function addEdge(a, b) {
    for (let i = 0; i <= PPE; i++) {
      const t = i / PPE;
      parts.push({
        x: a.x + (b.x - a.x) * t,
        y: a.y + (b.y - a.y) * t,
        z: a.z + (b.z - a.z) * t,
        col: COLS[Math.floor(Math.random() * COLS.length)]
      });
    }
  }
  for (let i = 0; i < 6; i++) {
    addEdge(front[i], front[(i + 1) % 6]);
    addEdge(back[i],  back[(i + 1) % 6]);
    addEdge(front[i], back[i]);
  }

  let ry = 0;
  const rx = -.35;
  const rotY = (x, z, a) => ({ x: x*Math.cos(a)-z*Math.sin(a), z: x*Math.sin(a)+z*Math.cos(a) });
  const rotX = (y, z, a) => ({ y: y*Math.cos(a)-z*Math.sin(a), z: y*Math.sin(a)+z*Math.cos(a) });

  function frame() {
    requestAnimationFrame(frame);
    if (cvs.width === 0) return;
    c.clearRect(0, 0, cvs.width, cvs.height);
    ry += .012 * rotDir;

    const list = parts.map(p => {
      const Y  = rotY(p.x, p.z, ry);
      const X  = rotX(p.y, Y.z, rx);
      const sc = 900 / (900 + X.z + 300);
      const dn = (X.z + 300) / 600;
      return {
        x: cvs.width  / 2 + Y.x * sc,
        y: cvs.height / 2 + X.y * sc,
        z: X.z,
        alpha: .14 + dn * .86,
        col:   p.col
      };
    });

    list.sort((a, b) => a.z - b.z);
    for (const p of list) {
      c.globalAlpha = p.alpha;
      c.beginPath();
      c.arc(p.x, p.y, 1.9, 0, Math.PI * 2);
      c.fillStyle = p.col;
      c.fill();
    }
    c.globalAlpha = 1;
  }
  frame();
})();

/* ═══════════════════════════════════════════════
   DOWNLOAD — HEX LOGO REVEAL
   Draws the Deseraq mark stroke-by-stroke,
   colour-shifts from blue → purple → orange,
   settles into brand purple with orange glow.
   Triggered when section scrolls into view.
═══════════════════════════════════════════════ */
(function hexReveal() {
  const cvs = document.getElementById('dl-cvs');
  if (!cvs) return;
  const c = cvs.getContext('2d');

  const pts = [
    { x:-140, y:-70 }, // 0
    { x:-140, y: 38 }, // 1
    { x: -82, y:132 }, // 2
    { x:  44, y:132 }, // 3
    { x: 106, y: 38 }, // 4
    { x:  44, y:-70 }, // 5
    { x: -82, y:-70 }  // 6
  ];

  const SEG   = 600;
  const BUILD = (pts.length - 1) * SEG;
  const ENERGY= 900;
  const OSC   = 300;

  const BLUE  = [120, 220, 255];
  const PURP  = [170,  80, 255];
  const ORA   = [255, 125,   0];
  const RED   = [255,  35,  35];

  // Final brand colors
  const FINAL_S = [139,  92, 246];
  const FINAL_G = [249, 115,  22];

  let t0 = null, running = false;

  const lerp   = (a, b, t) => a + (b - a) * t;
  const mix    = (a, b, t) => [lerp(a[0],b[0],t), lerp(a[1],b[1],t), lerp(a[2],b[2],t)];
  const toRgb  = v => `rgb(${v[0]|0},${v[1]|0},${v[2]|0})`;
  const cl01   = v => Math.max(0, Math.min(1, v));

  // Cumulative lengths for wave positioning
  const cum = [0];
  for (let i = 1; i < pts.length; i++) {
    cum[i] = cum[i-1] + Math.hypot(pts[i].x-pts[i-1].x, pts[i].y-pts[i-1].y);
  }
  const totLen = cum[cum.length-1];

  function dot(x, y, col, r) {
    c.save(); c.fillStyle = col;
    c.beginPath(); c.arc(x, y, r || 5.2, 0, Math.PI*2); c.fill(); c.restore();
  }
  function arrow(x, y, ang, col) {
    c.save(); c.translate(x, y); c.rotate(ang);
    c.fillStyle = col;
    c.beginPath(); c.moveTo(18,0); c.lineTo(-8,8); c.lineTo(-2,0); c.lineTo(-8,-8);
    c.closePath(); c.fill(); c.restore();
  }

  function draw(now) {
    if (!running) return;
    if (!t0) t0 = now;
    const el    = now - t0;
    const done  = el >= BUILD;
    const ee    = el - BUILD;
    const edone = ee >= ENERGY;

    c.clearRect(0, 0, cvs.width, cvs.height);

    // Color progression: Blue → Purple → Orange → Red → Brand Purple
    let sc = BLUE, gc = [120, 220, 255];
    if (done && !edone) {
      const t = cl01(ee / ENERGY);
      if      (t < .33) { sc = mix(BLUE, PURP, t / .33);          gc = sc; }
      else if (t < .66) { sc = mix(PURP, ORA,  (t-.33)/.33);      gc = sc; }
      else              { sc = mix(ORA,  RED,   (t-.66)/.34);
                          gc = mix(ORA, [255,160,0], (t-.66)/.34); }
    }
    if (edone) { sc = FINAL_S; gc = FINAL_G; }

    const ss = toRgb(sc), gs = toRgb(gc);

    const seg  = el / SEG;
    const fSeg = Math.floor(seg);
    const par  = cl01(seg - fSeg);

    c.save();
    // Centre the mark in canvas — offset accounts for asymmetric shape
    c.translate(cvs.width / 2 + 17, cvs.height / 2 - 16);
    c.lineWidth   = 4;
    c.lineCap     = 'round';
    c.lineJoin    = 'round';
    c.strokeStyle = ss;
    c.shadowColor = gs;
    c.shadowBlur  = done ? 22 : 14;
    c.beginPath();

    let started = false, ax = pts[0].x, ay = pts[0].y, aa = 0;

    for (let i = 0; i < pts.length - 1; i++) {
      const A = pts[i], B = pts[i+1];
      const vt = i < fSeg ? 1 : i === fSeg ? par : 0;
      if (vt <= 0) break;

      for (let s = 0; s <= 24; s++) {
        const u = (s / 24) * vt;
        let x = lerp(A.x, B.x, u);
        let y = lerp(A.y, B.y, u);

        // Short oscillation burst right after build completes
        if (done && !edone && ee <= OSC) {
          const tt  = ee / OSC;
          const amp = 18 * Math.sin(Math.PI * tt) * Math.exp(-.8 * tt);
          const ph  = tt * 28;
          const dx  = B.x - A.x, dy = B.y - A.y;
          const len = Math.hypot(dx, dy) || 1;
          const nx  = -dy / len, ny = dx / len;
          const pp  = (cum[i] + Math.hypot(dx, dy) * u) / totLen;
          const w   = Math.sin(pp * 20 - ph) * amp;
          x += nx * w; y += ny * w;
        }

        if (!started) { c.moveTo(x, y); started = true; }
        else          { c.lineTo(x, y); }
      }

      if      (i < fSeg)  { ax = B.x; ay = B.y; aa = Math.atan2(B.y-A.y, B.x-A.x); }
      else if (i === fSeg){ ax = lerp(A.x,B.x,par); ay = lerp(A.y,B.y,par); aa = Math.atan2(B.y-A.y, B.x-A.x); }
    }
    c.stroke();

    // Vertex dots
    const nv = Math.min(fSeg + 1, pts.length);
    const dr = (done && !edone && ee <= OSC) ? 5.8 : 5.2;
    for (let i = 0; i < nv; i++) dot(pts[i].x, pts[i].y, ss, dr);

    // Leading arrow
    if (done) {
      const last = pts[pts.length-1], prev = pts[pts.length-2];
      arrow(last.x, last.y, Math.atan2(last.y-prev.y, last.x-prev.x), ss);
    } else {
      arrow(ax, ay, aa, ss);
    }

    c.restore();
    requestAnimationFrame(draw);
  }

  // Fire when download section enters viewport
  new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting && !running) {
        running = true; t0 = null;
        requestAnimationFrame(draw);
      }
    });
  }, { threshold: .25 }).observe(cvs);
})();
</script>
</body>
